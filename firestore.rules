rules_version = '2';

// ──────────────────────────────────────────────────────────────
//  Firestore rules for the Be Different retreat app.
//
//  This app has NO backend server and the admin login is a simple
//  shared credential (not Firebase Auth), so by default we keep
//  the single "app" collection publicly readable and writable.
//
//  ⚠️  This is acceptable for a short, private, time-boxed retreat
//      where only trusted leaders know the site. For stronger
//      protection, switch admin actions to Firebase Authentication
//      and replace the write rule with: allow write: if request.auth != null;
// ──────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {
    match /app/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
